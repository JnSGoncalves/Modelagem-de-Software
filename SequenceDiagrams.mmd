%% UC-01
sequenceDiagram
    actor Cliente
    participant Sistema
    participant EmailService as "Serviço de Email"

    Cliente->>Sistema: inserirEmail()

    Sistema->>EmailService: enviarCodigoConfirmacao(email)
    EmailService-->>Cliente: receberCodigo()

    Cliente->>Sistema: confirmarCodigo(codigo)

    alt Código válido
        Sistema-->>Cliente: solicitarDadosPessoais()

        Cliente->>Sistema: enviarDados(nome, cpf, etc)

        Sistema->>Sistema: verificarDadosValidos()

        alt Dados válidos e únicos
            Sistema-->>Cliente: cadastroConfirmado()
        else Email ou CPF já existente
            Sistema-->>Cliente: informarContaExistente()
        end

    else Código inválido
        Sistema-->>Cliente: erroCodigo()
    end



%% UC-02
sequenceDiagram
    actor Cliente
    participant Sistema
    actor SistemaPagamento as "Sistema de Pagamento"
    participant EmailService as "Serviço de Email"

    Cliente->>Sistema: acessarAreaFidelidade()
    Cliente->>Sistema: clicarAderir()

    Cliente->>Sistema: inserirDadosCartao()

    Sistema->>SistemaPagamento: enviarDadosCartao()

    alt Cartão válido e com limite
        SistemaPagamento-->>Sistema: assinaturaAprovada()

        Sistema->>EmailService: enviarEmailConfirmacao()
        EmailService-->>Cliente: detalhesContratacao()

        Sistema-->>Cliente: confirmarCadastroFidelidade()

    else Dados inválidos
        SistemaPagamento-->>Sistema: erroDadosCartao()
        Sistema-->>Cliente: informarErroDados()

    else Sem limite disponível
        SistemaPagamento-->>Sistema: limiteInsuficiente()
        Sistema-->>Cliente: informarLimiteInsuficiente()
    end



%% UC-03
sequenceDiagram
    actor Cliente
    participant Sistema
    actor SistemaPagamento as "Sistema de Pagamento"
    actor Validador as "Validador de Documentos"

    Cliente->>Sistema: realizarLogin()

    Sistema->>Sistema: verificarClienteFidelidade()

    alt Cliente fidelidade
        Sistema-->>Cliente: liberarMelhoresAssentos()
    else Cliente comum
        Sistema-->>Cliente: mostrarAssentosDisponiveis()
    end

    Cliente->>Sistema: escolherCinema()
    Cliente->>Sistema: escolherFilme()
    Cliente->>Sistema: escolherSessao()
    Cliente->>Sistema: escolherAssentos()

    Cliente->>Sistema: informarCPF()

    Cliente->>Sistema: escolherTipoIngresso()

    alt Meia entrada
        Sistema-->>Cliente: solicitarDocumento()
        Cliente->>Sistema: enviarDocumento()
        Sistema->>Validador: validarDocumento()
        Validador-->>Sistema: resultadoValidacao()

        alt Documento aprovado
            Sistema-->>Cliente: continuarReserva()
        else Documento rejeitado
            Sistema-->>Cliente: cancelarReserva()
        end
    end

    Cliente->>Sistema: inserirDadosCartao()

    Sistema->>SistemaPagamento: enviarDadosCartao()

    alt Pagamento aprovado
        SistemaPagamento-->>Sistema: confirmarPagamento()
        Sistema-->>Cliente: disponibilizarIngressos()
    else Pagamento recusado
        SistemaPagamento-->>Sistema: pagamentoRecusado()
        Sistema-->>Cliente: solicitarOutroPagamento()
    end



%% UC-04
sequenceDiagram
    participant Sistema
    actor SistemaPagamento

    Sistema->>SistemaPagamento: enviarDadosCartao(dadosCartao)

    SistemaPagamento->>SistemaPagamento: validarCartao(dadosCartao)

    alt Cartão válido
        SistemaPagamento->>SistemaPagamento: processarPagamento(valor)

        alt Saldo/limite suficiente
            SistemaPagamento-->>Sistema: confirmarTransacao()
        else Sem saldo/limite
            SistemaPagamento-->>Sistema: transacaoNaoAprovada()
        end

    else Cartão inválido
        SistemaPagamento-->>Sistema: erroCartaoInvalido()
    end



%% UC-05
sequenceDiagram
    actor Cliente
    participant Sistema
    participant Ingresso
    actor SistemaPagamento as "Sistema de Pagamento"

    Cliente->>Sistema: acessarMeusIngressos()

    Sistema->>Ingresso: buscarIngressosCliente()
    Ingresso-->>Sistema: listaIngressos()

    Sistema-->>Cliente: mostrarIngressos()

    alt Cliente deseja pagar ingresso pendente
        Cliente->>Sistema: selecionarIngressoPendente()

        Sistema->>SistemaPagamento: enviarDadosPagamento()

        alt Pagamento aprovado
            SistemaPagamento-->>Sistema: confirmarTransacao()
            Sistema->>Ingresso: atualizarStatusPagamento()
            Sistema-->>Cliente: ingressoConfirmado()
        else Sem saldo ou limite
            SistemaPagamento-->>Sistema: pagamentoNaoAprovado()
            Sistema-->>Cliente: informarFalhaPagamento()
        end
    end

    alt Cliente deseja exportar ingresso
        Cliente->>Sistema: selecionarIngressoPago()
        Sistema->>Ingresso: gerarArquivoIngresso()
        Sistema-->>Cliente: exportarIngresso()
    end


%% UC-06
sequenceDiagram
    actor Administrador
    participant Sistema
    participant AdministradorClasse as Administrador
    
    Administrador->>Sistema: acessar app administrativo
    Administrador->>Sistema: selecionar "Cadastrar Administrador"
    Sistema->>Administrador: exibir formulário
    
    Administrador->>Sistema: enviar dados do cadastro
    Sistema->>Sistema: validar dados
    
    alt CPF válido e não cadastrado
        Sistema->>AdministradorClasse: cadastrarAdministrador()
        Sistema-->>Administrador: confirmação de cadastro
    else CPF inválido ou já cadastrado
        Sistema-->>Administrador: exibir erro
    end



%% UC-07
sequenceDiagram
    actor Administrador
    participant Sistema
    participant Cinema
    
    Administrador->>Sistema: acessar app administrativo
    Administrador->>Sistema: selecionar "Cadastrar Cinema"
    
    Sistema->>Administrador: exibir formulário de cinema
    Administrador->>Sistema: enviar dados do cinema
    
    Sistema->>Sistema: validar informações
    
    alt Dados válidos
        Sistema->>Cinema: criar cinema
        Sistema-->>Administrador: confirmação
    else Dados inválidos ou cinema já existente
        Sistema-->>Administrador: exibir erro
    end



%% UC-08
sequenceDiagram
    actor Administrador
    participant Sistema
    participant Filme
    participant AncineAPI
    
    Administrador->>Sistema: acessar app administrativo
    Administrador->>Sistema: selecionar "Gerenciar Filme"
    
    Sistema->>Filme: listar filmes
    Sistema-->>Administrador: exibir lista
    
    Administrador->>Sistema: escolher ação (cadastrar/editar/remover)
    
    alt Cadastrar filme
        Sistema->>Administrador: solicitar dados
        Administrador->>Sistema: enviar dados
        Sistema->>AncineAPI: consultar registro
        Sistema->>Filme: criar filme
    else Editar filme
        Administrador->>Sistema: informar alterações
        Sistema->>Filme: atualizarDados()
    else Remover filme
        Administrador->>Sistema: confirmar remoção
        Sistema->>Filme: remover()
    end
    
    Sistema-->>Administrador: exibir confirmação



%% UC-09
    sequenceDiagram
    actor Administrador
    participant Sistema
    participant Sessao
    participant Sala
    participant Filme
    
    Administrador->>Sistema: acessar app administrativo
    Administrador->>Sistema: selecionar "Gerenciar Sessão"
    
    Sistema->>Sessao: listar sessões
    Sistema-->>Administrador: exibir lista
    
    Administrador->>Sistema: escolher ação
    
    alt Criar sessão
        Sistema->>Administrador: solicitar dados
        Administrador->>Sistema: informar dados
        Sistema->>Sala: verificar disponibilidade
        Sistema->>Sessao: criar sessão
    else Editar sessão
        Administrador->>Sistema: alterar dados
        Sistema->>Sessao: atualizar sessão
    else Remover sessão
        Administrador->>Sistema: confirmar remoção
        Sistema->>Sessao: remover sessão
    end
    
    Sistema-->>Administrador: confirmação


%% UC-10
sequenceDiagram
    actor Administrador
    participant Sistema
    participant Sessao
    participant Sala
    
    Administrador->>Sistema: acessar app administrativo
    Administrador->>Sistema: selecionar "Gerenciar Melhores Assentos"
    
    Sistema->>Sessao: obter sessão
    Sistema->>Sala: obter mapa de assentos
    Sistema-->>Administrador: exibir mapa
    
    Administrador->>Sistema: selecionar assentos
    
    Sistema->>Sala: validarAssento()
    
    alt Assentos válidos
        Sistema->>Sala: definirMelhoresAssentos()
        Sistema-->>Administrador: confirmação
    else Assentos inválidos
        Sistema-->>Administrador: exibir erro
    end



%%  UC-11
sequenceDiagram
    actor Administrador
    participant Sistema
    participant Cinema
    participant Relatorio
    participant AncineAPI
    
    Administrador->>Sistema: acessar app administrativo
    Administrador->>Sistema: selecionar "Emitir Relatório"
    
    Sistema->>Cinema: coletar dados
    Sistema->>Relatorio: gerarPorCinema()
    Sistema->>Relatorio: gerarPorFilme()
    Sistema->>Relatorio: gerarPorSessao()
    
    Sistema->>Relatorio: exportar()
    
    Sistema->>AncineAPI: enviarRelatorio()
    
    Sistema-->>Administrador: exibir relatório



%% UC-12
sequenceDiagram
    actor Ancine
    participant Sistema
    participant Filme
    participant AncineAPI
    
    Sistema->>AncineAPI: solicitar lista de filmes
    AncineAPI-->>Sistema: retornar filmes
    
    Sistema->>Filme: atualizar lista local
    Sistema-->>Ancine: exibir lista de filmes
    
    alt Nenhum filme disponível
        Sistema-->>Ancine: informar ausência de filmes
    end



%% UC-13
sequenceDiagram
    participant Sistema
    participant Relatorio
    participant AncineAPI
    actor Ancine

    Sistema->>Relatorio: gerarRelatorio()

    alt Relatório gerado com sucesso
        Sistema->>AncineAPI: enviarRelatorio(relatorio)
        AncineAPI->>Ancine: enviarRelatorio(relatorio)
        Ancine-->>AncineAPI: confirmarRecebimento()
        AncineAPI-->>Sistema: confirmação
    else Erro ao gerar relatório
        Relatorio-->>Sistema: erro
    end

